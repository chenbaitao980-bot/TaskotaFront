<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- debug 构建允许明文流量 + 信任用户安装的 CA 证书（方便抓包调试） -->
    <debug-overrides>
        <trust-anchors>
            <certificates src="system" />
            <certificates src="user" />
        </trust-anchors>
    </debug-overrides>
</network-security-config>
